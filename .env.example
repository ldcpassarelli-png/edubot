# ============================================================
# EduBot — Variáveis de Ambiente
# Copie para .env e preencha os valores
# ============================================================

# Anthropic (Claude API)
ANTHROPIC_API_KEY=sk-ant-...
PARSER_MODEL=claude-haiku-4-5-20251001

# Banco de dados
DATABASE_URL=postgresql+asyncpg://edubot:edubot@localhost:5432/edubot

# WhatsApp Business API (Meta)
WA_VERIFY_TOKEN=edubot-verify-token
WA_APP_SECRET=seu_app_secret_aqui
WA_PHONE_NUMBER_ID=seu_phone_number_id
WA_ACCESS_TOKEN=seu_access_token

# Redis (cache e Celery)
REDIS_URL=redis://localhost:6379/0

# App
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SQL_DEBUG=false
